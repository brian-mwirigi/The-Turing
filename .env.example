# =====================================================================
# The Turing-Complete Canvas — environment variables
# =====================================================================
# LIVE (default for this example): set FAL_KEY. Florence-2, LLM A2UI slates,
# LTX-2.3 extend-video (seeded from public/canvas/room_seed.mp4), and Veo 3.1
# for the summon_operator hero beat.
# Without FAL_KEY the API routes fall back to mock detections + room_loop.
# ---------------------------------------------------------------------

# REQUIRED for live mode: your fal.ai API key (https://fal.ai/dashboard/keys)
FAL_KEY=

# OPTIONAL: model override for the LLM step (A2UI surface gen + prompt rewrite).
# Defaults to "google/gemini-2.5-flash". Any model on
# https://fal.run/openrouter/router/openai/v1 works.
FAL_LLM_MODEL=google/gemini-2.5-flash

# OPTIONAL credit savers (OFF by default — leave commented for full live / pitch).
# FAL_CHEAP=1         # mock detect, short LTX, skip Veo + prompt-rewrite LLM
# FAL_SKIP_LLM=1      # catalog slates + planBranch only
# FAL_MOCK_DETECT=1   # mock hotspots only (Florence off)
# FAL_SKIP_VEO=1      # summon_operator falls through to LTX / demo

# DATABASE_URL is required by the scaffold's Prisma schema.
# The canvas itself does not touch the database.
DATABASE_URL=file:./dev.db
